{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MICTEEJAY POS",
  "version": "0.1.0",
  "identifier": "com.micteejay.pos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MICTEEJAY POS",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/micteejay/pos-update/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3MjVCQTVDNjY3NDQzNDkKUldSSlEzUm1YTG9sOTRLeDd2NGdQdm82Y3ZFNzk4Ulh4Yis3akZMZkdqSkRhYjlSZ3daU1NLQ1YK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}